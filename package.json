{
  "name": "goose",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "pnpm sandbox:dev",
    "build": "pnpm core:build && pnpm vite:build",
    "type-check": "pnpm -r --if-present type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm type-check && pnpm test && pnpm build",
    "core:dev": "pnpm -C packages/core dev",
    "core:build": "pnpm -C packages/core build",
    "sandbox:dev": "pnpm -C packages/sandbox dev",
    "sandbox:build": "pnpm -C packages/sandbox build",
    "vite:dev": "pnpm -C packages/vite dev",
    "vite:build": "pnpm -C packages/vite build",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.2.1",
    "defu": "^6.1.4",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^7.0.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.10.0"
}
