{
  "name": "@jclong98/goose",
  "version": "0.0.3",
  "private": false,
  "description": "Core Vue components, composables, directives, and styles for Goose",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/goose.umd.cjs",
  "module": "./dist/goose.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/goose.js",
      "require": "./dist/goose.umd.cjs"
    },
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.umd.cjs"
    },
    "./composables": {
      "types": "./dist/types/composables/index.d.ts",
      "import": "./dist/composables.js",
      "require": "./dist/composables.umd.cjs"
    },
    "./directives": {
      "types": "./dist/types/directives/index.d.ts",
      "import": "./dist/directives.js",
      "require": "./dist/directives.umd.cjs"
    },
    "./style.css": "./dist/core.css",
    "./tw-theme.css": "./dist/tw-theme.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build --mode lib",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.2.1",
    "defu": "^6.1.4",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^7.0.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tinyglobby": "^0.2.15",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitepress": "2.0.0-alpha.16",
    "vitest": "^4.0.18",
    "vue-component-meta": "^3.2.5",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
